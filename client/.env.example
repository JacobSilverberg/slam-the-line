# Backend API URL (set to your Railway backend URL in production)
VITE_API_URL=http://localhost:3000

# Current NFL season year and start date (update each season)
VITE_NFL_YEAR=2025
VITE_NFL_SEASON_START=2025-09-02

# Optional: default league ID to show a "join this league" prompt on the home page
# Leave unset to hide the prompt
VITE_DEFAULT_LEAGUE_ID=
